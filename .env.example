# GitHub App Client ID — enables "Connect with GitHub" button (OAuth web flow via Cloudflare Worker)
# Register at: github.com/settings/apps → New GitHub App
# Required permissions: Pull requests (read), Metadata (read)
# Enable "Request user authorization (OAuth) during installation"
# Optional — if omitted, only the manual PAT input is shown
VITE_GITHUB_CLIENT_ID=

# URL of the deployed Cloudflare Worker that handles the GitHub token exchange
VITE_GITHUB_WORKER_URL=https://pulldog-auth.<your-subdomain>.workers.dev

# OAuth redirect URI — defaults to window.location.origin if omitted
# Register both https://pulldog.dev and http://localhost:5173 in your GitHub OAuth App settings
VITE_GITHUB_REDIRECT_URI=

# GitHub Personal Access Token — fallback manual auth method
# Optional — if omitted, the token can be entered via the UI and is stored in localStorage
VITE_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Warning threshold: PR turns amber after this many hours
VITE_SLA_WARNING_HOURS=24

# Breach threshold: PR turns red after this many hours
VITE_SLA_BREACH_HOURS=72

# Comment fire threshold: show 🔥 next to comment count when it reaches this number
VITE_COMMENT_FIRE_THRESHOLD=10

# Test mode: shows sound test buttons in the toolbar (true | false)
VITE_TEST_MODE=false

# OpenAI API key for TTS (text-to-speech) merge announcements
# Required for "Hey [author], your PR has been merged" announcements
# Get your key at: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
